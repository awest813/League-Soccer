# Doxyfile for League-Soccer / Gameplay Football
# Generated for Phase 5.1 – API documentation with Doxygen
#
# Run:  doxygen Doxyfile
# Output: docs/html/index.html

#---------------------------------------------------------------------------
# Project identity
#---------------------------------------------------------------------------
PROJECT_NAME           = "Gameplay Football"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Open-source 3-D association-football simulation in C++17"
PROJECT_LOGO           =

#---------------------------------------------------------------------------
# Input / output
#---------------------------------------------------------------------------
OUTPUT_DIRECTORY       = docs
INPUT                  = src README.md ARCHITECTURE.md
FILE_PATTERNS          = *.cpp *.hpp *.h *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

# Exclude build artefacts, third-party headers and test helpers
EXCLUDE_PATTERNS       = */build/* */tests/* */.git/*

#---------------------------------------------------------------------------
# Extraction settings
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

#---------------------------------------------------------------------------
# LaTeX / man-page output (disabled by default – enable if needed)
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Diagrams  (set HAVE_DOT = YES if Graphviz is installed for richer graphs)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

#---------------------------------------------------------------------------
# Miscellaneous
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
